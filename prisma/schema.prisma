// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id              String          @id
  email           String          @unique
  passwordHash    String
  displayName     String
  createdAt       DateTime        @default(now())

  progressEntries ProgressEntry[]
  wallet           Wallet?
  inventoryEntries InventoryEntry[]

  @@map("users")
}
model Level {
  id           String          @id
  index        Int             @unique
  difficulty   String
  rows         Int
  cols         Int
  arrows       Json
  walls        Json
  collectibles Json
  parTimeMs    Int
  timeLimitMs  Int?
  published    Boolean         @default(false)
  createdAt    DateTime        @default(now())

  progressEntries ProgressEntry[]

  @@map("levels")
}
model ProgressEntry {
  id          String   @id
  userId      String
  levelId     String
  moves       Int
  timeMs      Int
  stars       Int
  attempts    Int
  completedAt DateTime
  updatedAt   DateTime @default(now()) @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  level Level @relation(fields: [levelId], references: [id])

  @@unique([userId, levelId])
  @@map("progress_entries")
}

model Wallet {
  userId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model InventoryEntry {
  userId  String
  itemId  String
  addedAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id])
  item ShopItem @relation(fields: [itemId], references: [id])

  @@id([userId, itemId])
  @@map("inventory_entries")
}

model ShopItem {
  id        String   @id
  name      String
  costCoins Int
  kind      String
  createdAt DateTime @default(now())

  inventoryEntries InventoryEntry[]

  @@map("shop_items")
}