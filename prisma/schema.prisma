// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Level {
  id         String   @id
  index      Int      @unique
  difficulty String
  rows       Int
  cols       Int
  cells      Json
  parTimeMs  Int
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("levels")
}