# Postgres connection string. Include ?schema=public.
DATABASE_URL="postgresql://user@localhost:5432/arrowmaze?schema=public"

# JWT signing secret. MUST be at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string-min-32-chars"

# JWT expiry (ms/s/m/h/d format from the `ms` package).
JWT_EXPIRES_IN="7d"

# HTTP port. Defaults to 3000 if unset.
PORT=3000

# Admin key for level upsert endpoints (used in Fase 6).
# Leave blank until Fase 6.
ADMIN_API_KEY=""